# Qwen Cloud (Alibaba Cloud Model Studio / DashScope), OpenAI-compatible endpoint
DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Flagship Qwen text model on Model Studio. qwen3.7-max is the current flagship;
# qwen-plus is a reliable lower-cost fallback if the flagship is not enabled on the account.
LEDGERPILOT_PLANNER_MODEL=qwen3.7-max
LEDGERPILOT_VISION_MODEL=qwen3-vl-plus

# Governed write-back signing key (HMAC). Generate with: python -c "import secrets;print(secrets.token_hex(32))"
LEDGERPILOT_SIGNING_KEY=

# Approval threshold: entries with absolute amount above this require human-in-the-loop approval
LEDGERPILOT_APPROVAL_THRESHOLD=10000

# Alibaba Cloud Odoo (system of record), used by writeback.py / odoo_client.py
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_API_KEY=

# SSE endpoint of the Odoo MCP server, reachable from Model Studio's Responses API
# (only needed for the ModelStudioMcpClient write path)
ODOO_MCP_SERVER_URL=
